meta {
  name: GET blogs -categoryIds single-
  type: http
  seq: 11
}

get {
  url: {{BASE_URL}}/blogs?categoryIds=1
  body: none
  auth: none
}

params:query {
  categoryIds: 1
}

tests {
  const expectedNumBlogs = 3;
  const expectedCountBlogs = 3;
  
  test("Status code is 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("Valid blog list length", function() {
      try {
          var data = res.getBody();
          expect(data.blogs.length).to.equal(expectedNumBlogs);
      } catch (err) {
          expect.fail(`Incorrect number of blogs returned expected ${expectedNumBlogs} got ${res.getBody().blogs.length}`);
      }
  });
  
  test("Valid blog count", function() {
      try {
          var data = res.getBody();
          expect(data.count).to.equal(expectedCountBlogs);
      } catch (err) {
          expect.fail(`Incorrect blogs count expected ${expectedCountBlogs} got ${res.getBody().blogs.length}`);
      }
  });
  
  
  var expectedOrdering = [33, 17, 1] ;
  
  test("Valid ids and ordering", function() {
      try {
          var blogs = res.getBody().blogs;
  //         console.log(`blogs [${blogs.map(b => b.blogId)}]`);
          for (var i = 0; i<expectedOrdering.length; i++){
              if (expectedOrdering[i] !== blogs[i].blogId){
                  expect.fail("Invalid ordering of blogs");
                  break;
              }
          }
      } catch (err) {
          expect.fail("Invalid ordering of blogs (ERROR OCCURRED)");
      }
  });
}
